# Backend base URL. Set to "" (empty) to go same-origin through the vite dev proxy.
VITE_API_BASE=http://127.0.0.1:8001

# Set to 1 to force the built-in mock dataset (no backend needed).
# When unset, the app tries the live API and auto-falls back to mock if unreachable.
VITE_USE_MOCK=

# Private /tracking route (Supabase GoTrue + tracking_* tables)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
